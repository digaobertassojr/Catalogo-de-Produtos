cat > Views/Home/Index.cshtml << 'EOF'
@{
    var nomes   = ViewBag.Nomes   as List<string>;
    var precos  = ViewBag.Precos  as List<double>;
    var estoque = ViewBag.Estoques as List<int>;
}

<style>
    table { width: 100%; border-collapse: collapse; font-family: sans-serif; }
    th { background: #1e2436; color: #aaa; padding: 12px 16px; text-align: left; }
    td { padding: 12px 16px; border-bottom: 1px solid #eee; }
    .preco-baixo  { background: #d4f5e9; color: #0a7c4e; padding: 4px 10px; border-radius: 6px; font-weight: bold; }
    .preco-medio  { background: #fef9c3; color: #92680a; padding: 4px 10px; border-radius: 6px; font-weight: bold; }
    .preco-alto   { background: #ffe4d6; color: #c0440f; padding: 4px 10px; border-radius: 6px; font-weight: bold; }
    .status-ok    { background: #d4f5e9; color: #0a7c4e; padding: 3px 10px; border-radius: 20px; }
    .status-low   { background: #fef9c3; color: #92680a; padding: 3px 10px; border-radius: 20px; }
    .status-esgot { background: #ffe4e6; color: #b91c1c; padding: 3px 10px; border-radius: 20px; }
</style>

<h2 style="font-family:sans-serif; margin: 20px;">Catálogo de Produtos</h2>

<table>
    <thead>
        <tr>
            <th>#</th>
            <th>Produto</th>
            <th>Preço</th>
            <th>Estoque</th>
        </tr>
    </thead>
    <tbody>
        @for (int i = 0; i < nomes.Count; i++)
        {
            string cssPreco;
            if (precos[i] < 100)
            {
                cssPreco = "preco-baixo";
            }
            else if (precos[i] <= 500)
            {
                cssPreco = "preco-medio";
            }
            else
            {
                cssPreco = "preco-alto";
            }
            <tr>
                <td>@(i + 1)</td>
                <td>@nomes[i]</td>
                <td>
                    <span class="@cssPreco">
                        R$ @precos[i].ToString("F2")
                    </span>
                </td>
                <td>
                    @if (estoque[i] == 0)
                    {
                        <span class="status-esgot">Esgotado</span>
                    }
                    else if (estoque[i] < 10)
                    {
                        <span class="status-low">Baixo</span>
                    }
                    else
                    {
                        <span class="status-ok">Em estoque</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

<p style="font-family:sans-serif; margin: 20px;">Total: @nomes.Count produtos</p>
EOF